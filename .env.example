# ─────────────────────────────────────────────────────────────────
# SEO Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── URLs ──────────────────────────────────────────────────────────
APP_URL=https://seo-agent.onrender.com
FRONTEND_URL=https://seo-agent-6jrv.onrender.com

# ── Firebase Admin (server-side) ──────────────────────────────────
# Download from Firebase Console > Project Settings > Service Accounts
FIREBASE_PROJECT_ID=your-project-id
GOOGLE_APPLICATION_CREDENTIALS=./seo-agent-firebase-adminsdk.json

# ── Firebase Client (frontend via Vite) ───────────────────────────
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# ── Frontend API URL (Vite) ───────────────────────────────────────
VITE_API_URL=https://seo-agent-backend-8mfz.onrender.com

# ── LLM Keys (stored per-user in Firestore, but can set defaults) ─
# Users add their own keys in Settings. These are optional defaults.
GROQ_API_KEY=gsk_...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...

# ── SEO Data APIs ─────────────────────────────────────────────────
SERPAPI_KEY=...
SERANKING_API_KEY=...

# ── Google APIs ───────────────────────────────────────────────────
# For Google Search Console + Google Business Profile OAuth
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# GA4 property ID (e.g. 123456789)
GA_PROPERTY_ID=

# ── Email (Nodemailer) ────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=SEO Agent <noreply@yourdomain.com>

# ── JWT ───────────────────────────────────────────────────────────
JWT_SECRET=your-very-long-random-secret-min-32-chars

# ── Stripe (for billing, optional) ───────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
